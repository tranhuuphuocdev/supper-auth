{
  "info": {
    "name": "Auth Service API",
    "description": "REST API for authentication service with JWT and RBAC",
    "version": "1.0.0"
  },
  "auth": [],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "http://localhost:8080/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "http://localhost:8080/api/v1/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "http://localhost:8080/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/v1/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE"
              }
            ]
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "http://localhost:8080/api/v1/auth/change-password",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"password123\",\n  \"new_password\": \"newpassword456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Users",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/v1/admin/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              }
            ]
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/v1/admin/users/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              }
            ]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "http://localhost:8080/api/v1/admin/users/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Smith\",\n  \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:8080/api/v1/admin/users/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - Roles",
      "item": [
        {
          "name": "List All Roles",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/v1/admin/roles",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              }
            ]
          }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "url": "http://localhost:8080/api/v1/admin/roles",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"editor\",\n  \"description\": \"Editor role with publishing permissions\"\n}"
            }
          }
        },
        {
          "name": "Assign Role to User",
          "request": {
            "method": "POST",
            "url": "http://localhost:8080/api/v1/admin/users/1/roles",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role_id\": 2\n}"
            }
          }
        },
        {
          "name": "Remove Role from User",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:8080/api/v1/admin/users/1/roles/2",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - Permissions",
      "item": [
        {
          "name": "List All Permissions",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/v1/admin/permissions",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN"
              }
            ]
          }
        }
      ]
    }
  ]
}
